# ── Veritabanı ──────────────────────────────────────────────────────────────
DB_USER=aractakip
DB_PASSWORD=GUCLU_SIFRE_GIR
DB_NAME=aractakip

# ── JWT ─────────────────────────────────────────────────────────────────────
# Üretmek için: openssl rand -base64 32
JWT_SECRET=BURAYA_GUCLU_SECRET_GIR

# ── CORS ────────────────────────────────────────────────────────────────────
# Nginx proxy kullandığı için backend'in kendi IP/domain'i yeterlidir.
# Birden fazla origin: http://domain1.com,http://domain2.com
CORS_ALLOWED_ORIGINS=http://SUNUCU_IP_VEYA_DOMAIN
